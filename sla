-- 10. consultar produtos do joão silva em ordem alfabética
select pr.nome, ip.quantidade 
from db_loja_online.clientes c
join db_loja_online.pedidos p on c.id = p.cliente_id
join db_loja_online.itens_pedido ip on p.id = ip.pedido_id
join db_loja_online.produtos pr on ip.produto_id = pr.id
where c.nome like "joão silva"
order by pr.nome asc;




