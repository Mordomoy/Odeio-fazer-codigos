-- 1. criar o banco de dados
create database db_loja_online;

-- 2. criar a tabela de clientes
create table db_loja_online.clientes(
    id int primary key,
    nome varchar(100) not null,
    email varchar(100) not null unique
);

-- 3. criar a tabela de produtos
create table db_loja_online.produtos(
    id int primary key,
    nome varchar(100) not null,
    preco decimal(10,2) not null
);

-- 4. criar a tabela de pedidos
create table db_loja_online.pedidos(
    id int primary key,
    cliente_id int not null,
    data_pedido date not null,
    foreign key (cliente_id) references db_loja_online.clientes(id)
);

-- 5. criar a tabela de itens do pedido
create table db_loja_online.itens_pedido(
    id int primary key,
    pedido_id int not null,
    produto_id int not null,
    quantidade int not null,
    foreign key (pedido_id) references db_loja_online.pedidos(id),
    foreign key (produto_id) references db_loja_online.produtos(id)
);





